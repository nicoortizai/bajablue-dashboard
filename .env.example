# Single shared password gate. Set on Vercel for production.
# If unset, the app falls back to a dev password ("bajablue") so
# local development works without env wiring.
ADMIN_PASSWORD=change-me

# --- Live Google Ads API ---
# All five must be set for the Ads sections to switch from seed to live.
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=    # MCC id, no dashes (optional but typical)
# GOOGLE_ADS_CUSTOMER_ID=2252665731

# --- Search Console (Organic vs Paid + Top Queries) ---
# Reuse GOOGLE_ADS_CLIENT_ID/SECRET if the same OAuth client includes the GSC scope.
# Otherwise set GSC_CLIENT_ID/GSC_CLIENT_SECRET to a different client.
# GSC_CLIENT_ID=
# GSC_CLIENT_SECRET=
# GSC_REFRESH_TOKEN=
# GSC_SITE_URL=https://www.bajablue.mx/    # or sc-domain:bajablue.mx

# --- DataForSEO (Competitor SoV + AI Overviews) ---
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=

# --- Optional Google Maps (Places API, for future GBP integration) ---
# GOOGLE_MAPS_PLACES_API_KEY=

# --- Vercel KV (optional — caches live data for 4h to reduce API quota) ---
# Set automatically when you provision a Vercel KV store. Without it the
# app uses an in-memory fallback that survives within a single edge isolate.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
