# Single shared password gate. Set on Vercel for production.
# If unset, the app falls back to a dev password ("bajablue") so
# local development works without env wiring.
ADMIN_PASSWORD=change-me

# --- Live Google Ads API (wired in step 2) ---
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_OAUTH_CLIENT_ID=
# GOOGLE_ADS_OAUTH_CLIENT_SECRET=
# GOOGLE_ADS_OAUTH_REFRESH_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_ADS_CUSTOMER_ID=2252665731
